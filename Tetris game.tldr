"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"shape and make it a row, but reversed. "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"For example the T piece [[0,1,0],[1,1,1]] becomes"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"[[1,0],[1,1],[1,0]]. fallingShape[0].map() goes through"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":" each column index. fallingShape.map(r => r[c])"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"picks that column from every row. .reverse()"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":" flips it to make the rotation go clockwise."}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"let oldShape = fallingShape;"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"fallingShape = rotatedShape;"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"if (pieceWillCrash(0, 0)) fallingShape = oldShape;"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"We save the old shape first. Try the rotation. "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"If the rotated shape immediately crashes (hits a wall or"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"block), we put the old shape back. This prevents rotating into a wall."}]}]}},"parentId":"page:page","index":"albLdH9V","typeName":"shape"},{"x":-19.593261282240462,"y":13034.515723300976,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:HgUS7DOuKrVtEYg20pH7v","type":"text","props":{"color":"black","size":"m","w":492.1382274984024,"font":"draw","textAlign":"start","autoSize":true,"scale":0.9236070189401722,"richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"co