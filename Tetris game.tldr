t (if safe)"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"     │     → : move right (if safe)"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"     │     ↓ : movePieceDownOneRow()"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"     │     ↑ : rotateFallingPiece()"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"     │     then: drawBoardOnScreen()"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"     │"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"     └──── Player clicks \"Start\" again = restart"}]}]}},"parentId":"page:page","index":"b0FIUz6Qt","typeName":"shape"},{"x":-69.84765625,"y":5794.08203125,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:eeSZhG7OSzzSCeIAwUk3O","type":"text","props":{"color":"black","size":"m","w":920,"font":"draw","textAlign":"start","autoSize":false,"scale":0.8656504755434783,"richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Section 3 — dropNewPieceFromTop() function dropNewPieceFromTop() { let randomIndex = Math.floor( Math.random() * allShapes.length ); fallingShape = allShapes[randomIndex]; fallingCol = 3; fallingRow = 0; } Math.random() gives a decimal number between 0 and 1, like 0.73. Multiply by the number of shapes (5) gives something like 3.65. Math.floor() chops off the decimal to get a whole number like 3. So we pick shape number 3 from allShapes randomly. Then we reset fallingCol to 3 (middle) and fallingRow to 0 (top) so the new piece starts at the top center."}]}]}},"parentId":"page:page","index":"aWkLvqZV","typeName":"shape"},{"x":341.49504681762903,"y":8055.483659109851,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:U_F7WzSzsvAv_6HbohrqW","type":"text","props":{"color":"black","size":"m","w":179.953125,"font":